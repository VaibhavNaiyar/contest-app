{
  "name": "@repo/db",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:push": "prisma db push --config prisma.config.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "typescript": "5.9.2"
  }
}
